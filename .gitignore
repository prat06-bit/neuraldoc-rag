# ── ENV / Secrets ──────────────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.yaml

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
.Python

# ── Virtual environments ────────────────────────────────────────────────────────
venv/
.venv/
.env/
env/

# ── Build / dist ────────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# ── Type checking / linting ─────────────────────────────────────────────────────
.mypy_cache/
.pyright/
pyrightconfig.json          # IDE-specific, not project config
.ruff_cache/

# ── Testing ─────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Logs ────────────────────────────────────────────────────────────────────────
*.log
logs/

# ── RAG runtime data (NEVER commit these) ───────────────────────────────────────
chroma_db/                  # vector store — rebuilt on ingest
uploaded_pdfs/              # user uploads — ephemeral
chat_history.json           # per-user session data
analytics.json              # runtime metrics

# ── Streamlit ───────────────────────────────────────────────────────────────────
.streamlit/secrets.toml     # API keys stored here

# ── uv / package managers ───────────────────────────────────────────────────────
uv.lock                     # lock file — commit only if you want reproducible installs
                            # (remove this line if you want to pin deps in CI)

# ── OS junk ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── VS Code ─────────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── JetBrains ───────────────────────────────────────────────────────────────────
.idea/

# ── Jupyter ─────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Misc temp files ─────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
tempCodeRunnerFile.*
Untitled*.html
Untitled*.py